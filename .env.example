# Optional local API token. Leave empty for local open access.
AXDATA_API_TOKEN=

# Local data layout.
AXDATA_HOME=.
AXDATA_DATA_DIR=./data
AXDATA_METADATA_DB=./metadata/axdata.sqlite

# Local service ports. Keep API and Web on different ports in development.
AXDATA_API_HOST=127.0.0.1
AXDATA_API_PORT=8666
AXDATA_WEB_HOST=127.0.0.1
AXDATA_WEB_PORT=8667
AXDATA_CORS_ORIGINS=

# SDK defaults.
AXDATA_API_BASE=http://127.0.0.1:8666
AXDATA_TOKEN=

# Web default API target.
VITE_AXDATA_API_BASE=http://127.0.0.1:8666
